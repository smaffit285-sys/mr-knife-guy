---
import { SEO } from '@wix/seo/components';
import { loadSEOTagsServiceConfig } from '@wix/seo/services';
import AppRouter from "@/components/Router";
import "@wix/wix-vibe-plugins/plugins-vars.css";
import "@wix/wix-vibe-plugins/plugins-theme.css";
import "@/styles/global.css";

const seoTagsServiceConfig = await loadSEOTagsServiceConfig({
  pageUrl: Astro.url.href,
  itemData: {
    pageName: 'Home',
  },
});
---

<html lang="en" class="w-full h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Miami Knife Guy | Professional Knife Sharpening Miami-Dade & Broward</title>
    <meta name="description" content="Master knife sharpening for Miami's top restaurants and home cooks. 17 years experience. Gary Danko, The French Laundry, Hotel Nikko. Pickup at last call, back before first prep. Serving Miami-Dade & Broward. Text SHARP to (305) 909-5773." />
    <meta name="keywords" content="knife sharpening Miami, restaurant knife sharpening Miami, professional knife sharpening South Florida, chef knife sharpening service Miami, knife sharpening Miami-Dade, knife sharpening Broward" />
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Miami Knife Guy",
      "description": "Master knife sharpening for Miami's top restaurants and home cooks. 17 years experience sharpening for Gary Danko, The French Laundry, Hotel Nikko, and Acquerello.",
      "telephone": "+13059095773",
      "email": "SMaffit@MiamiKnifeGuy.com",
      "url": "https://www.miamiknifeguy.com",
      "areaServed": ["Miami-Dade County", "Broward County", "North Miami Beach", "Aventura", "Sunny Isles", "Brickell", "Bal Harbour", "Hallandale Beach"],
      "serviceType": ["Knife Sharpening", "Restaurant Knife Sharpening", "Commercial Kitchen Knife Service"],
      "priceRange": "$$"
    })}</script>
    <SEO.Tags seoTagsServiceConfig={seoTagsServiceConfig} slot="seo-tags" />
  </head>
  <body class="w-full h-full">
    <div id="root" class="w-full h-full">
      <AppRouter client:only="react" />
    </div>
  </body>
</html>
